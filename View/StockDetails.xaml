<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectCompScience.View.StockDetails"
             BackgroundColor="#1E1E1E"
             Title="Details">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
            <HorizontalStackLayout Spacing="10" Grid.Column="0">
                <Border Stroke="#333" BackgroundColor="#2D2D2D" Padding="10,5">
                    <Label Text="{Binding Ticker}" FontAttributes="Bold" TextColor="White" />
                </Border>
                <Border Stroke="#333" BackgroundColor="#2D2D2D" Padding="10,5">
                    <Label Text="{Binding CompanyName}" TextColor="#A0A0A0" />
                </Border>
            </HorizontalStackLayout>

            <Button Grid.Column="1" Text="+ COMPARE" Command="{Binding AddCompareCommand}" BackgroundColor="#3498db" TextColor="White" FontAttributes="Bold" HeightRequest="35" Padding="15,0" CornerRadius="4"/>
        </Grid>

        <HorizontalStackLayout Spacing="10" Margin="0,5,0,0">
            <Border Stroke="#333" BackgroundColor="#2D2D2D" Padding="10,5">
                <Label Text="{Binding CurrentPrice}" FontAttributes="Bold" TextColor="White" />
            </Border>
            <Border Stroke="{Binding TrendColor}" BackgroundColor="#122A12" Padding="10,5">
                <Label Text="{Binding PercentageChange}" TextColor="{Binding TrendColor}" FontAttributes="Bold" />
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="10" Margin="0,5,0,0" IsVisible="{Binding IsCompare1Visible}">
            <Border Stroke="Cyan" BackgroundColor="#1A2B3C" Padding="10,5">
                <Label Text="{Binding Compare1Ticker}" TextColor="Cyan" FontAttributes="Bold" />
            </Border>
            <Label Text="{Binding Compare1Price}" TextColor="White" VerticalOptions="Center"/>
            <Label Text="{Binding Compare1Change}" TextColor="Cyan" VerticalOptions="Center"/>
            <Button Text="✕" Command="{Binding RemoveCompare1Command}" BackgroundColor="Transparent" TextColor="#FF5252" Padding="5,0" WidthRequest="30" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="10" Margin="0,5,0,0" IsVisible="{Binding IsCompare2Visible}">
            <Border Stroke="Gold" BackgroundColor="#332B14" Padding="10,5">
                <Label Text="{Binding Compare2Ticker}" TextColor="Gold" FontAttributes="Bold" />
            </Border>
            <Label Text="{Binding Compare2Price}" TextColor="White" VerticalOptions="Center"/>
            <Label Text="{Binding Compare2Change}" TextColor="Gold" VerticalOptions="Center"/>
            <Button Text="✕" Command="{Binding RemoveCompare2Command}" BackgroundColor="Transparent" TextColor="#FF5252" Padding="5,0" WidthRequest="30" />
        </HorizontalStackLayout>

        <FlexLayout JustifyContent="SpaceBetween" Margin="0,20,0,10">
            <Button Text="1W" Command="{Binding ChangeTimeRangeCommand}" CommandParameter="1W" BackgroundColor="Transparent" TextColor="#A0A0A0" />
            <Button Text="2W" Command="{Binding ChangeTimeRangeCommand}" CommandParameter="2W" BackgroundColor="Transparent" TextColor="#A0A0A0"/>
            <Button Text="1M" Command="{Binding ChangeTimeRangeCommand}" CommandParameter="1M" BackgroundColor="Transparent" TextColor="#A0A0A0" />
            <Button Text="2M" Command="{Binding ChangeTimeRangeCommand}" CommandParameter="2M" BackgroundColor="Transparent" TextColor="#A0A0A0" />
            <Button Text="3M" Command="{Binding ChangeTimeRangeCommand}" CommandParameter="3M" BackgroundColor="Transparent" TextColor="#A0A0A0" />
        </FlexLayout>

        <Border Stroke="#333" BackgroundColor="#252525" HeightRequest="250">
            <GraphicsView 
                x:Name="StockGraphView"
                Drawable="{Binding MyGraphDrawable}" 
                HorizontalOptions="Fill" 
                VerticalOptions="Fill" />
        </Border>

        <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
            <Button Grid.Column="0"
                    Text="BUY STOCK" 
                    Command="{Binding BuyStockCommand}" 
                    BackgroundColor="#2ECC71"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    Text="PREDICT AI" 
                    Command="{Binding PredictFutureCommand}" 
                    BackgroundColor="#9B59B6"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"/>
        </Grid>

        <Button Text="SELL STOCK" 
                Command="{Binding SellStockCommand}" 
                IsVisible="{Binding IsFromPortfolio}"
                BackgroundColor="#E74C3C"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="8"
                HeightRequest="50"
                Margin="0,0,0,0"/>

    </VerticalStackLayout>
</ContentPage>