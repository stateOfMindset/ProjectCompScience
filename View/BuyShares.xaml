<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

             x:Class="ProjectCompScience.View.BuyShares"

             xmlns:models="clr-namespace:ProjectCompScience.Models"

             Title="BuyShares">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="20">
        <VerticalStackLayout Grid.Row="0" Spacing="15">
            <Label Text="Search Markets" FontSize="28" FontAttributes="Bold" TextColor="White" />

            <Border BackgroundColor="#1A1A1A" Stroke="#2A2A2A" StrokeThickness="1" Padding="5,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <SearchBar x:Name="StockSearch"
                           Placeholder="Search company or ticker..."
                           PlaceholderColor="#888888"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           SearchCommand="{Binding SearchStocksCommand}"
                           SearchCommandParameter="{Binding Source={x:Reference StockSearch}, Path=Text}" />
            </Border>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding FilteredStocks}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding SelectStockCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,40,0,0" Spacing="10">
                    <Label Text="🔍" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="Find your next investment" TextColor="#888888" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:StockSymbol">

                    <Border BackgroundColor="#1A1A1A" Stroke="Transparent" Padding="15" Margin="0,0,0,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" 
                                   Text="{Binding Ticker}" 
                                   FontAttributes="Bold" 
                                   TextColor="{Binding ThemeColor}" 
                                   FontSize="18" 
                                   VerticalOptions="Center"
                                   WidthRequest="75"/>

                            <Label Grid.Column="1" 
                                   Text="{Binding Title}" 
                                   TextColor="#AAAAAA" 
                                   FontSize="14" 
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"/>
                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage> 

