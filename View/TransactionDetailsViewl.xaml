<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectCompScience.View.TransactionDetailsViewl"
             Title="Transaction Details"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Label Text="Receipt" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,10"/>
            <BoxView HeightRequest="1" Color="#333333" Margin="0,0,0,10"/>

            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto, Auto, Auto" RowSpacing="15">

                <Label Text="Asset:" TextColor="#AAAAAA" FontSize="16" Grid.Row="0" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.Ticker}" TextColor="White" FontSize="16" FontAttributes="Bold" Grid.Row="0" Grid.Column="1"/>

                <Label Text="Action:" TextColor="#AAAAAA" FontSize="16" Grid.Row="1" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.TransactionType}" TextColor="White" FontSize="16" Grid.Row="1" Grid.Column="1"/>

                <Label Text="Shares:" TextColor="#AAAAAA" FontSize="16" Grid.Row="2" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.Shares}" TextColor="White" FontSize="16" Grid.Row="2" Grid.Column="1"/>

                <Label Text="Price Per Share:" TextColor="#AAAAAA" FontSize="16" Grid.Row="3" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.PricePerShare, StringFormat='${0:F2}'}" TextColor="White" FontSize="16" Grid.Row="3" Grid.Column="1"/>

                <Label Text="ID:" TextColor="#AAAAAA" FontSize="16" Grid.Row="4" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.Id, StringFormat='#{0:F2}'}" TextColor="White" FontSize="16" Grid.Row="4" Grid.Column="1"/>

            </Grid>

            <BoxView HeightRequest="1" Color="#333333" Margin="0,15"/>

            <Grid ColumnDefinitions="*, Auto">
                <Label Text="Total:" TextColor="#AAAAAA" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" Grid.Column="0"/>
                <Label Text="{Binding CurrentTransaction.TotalAmount, StringFormat='${0:F2}'}" TextColor="#2ECC71" FontSize="24" FontAttributes="Bold" Grid.Column="1"/>
            </Grid>

            <Label Text="{Binding CurrentTransaction.Date, StringFormat='{0:f}'}" TextColor="#777777" FontSize="12" HorizontalOptions="Center" Margin="0,40,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>