<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectCompScience.View.StockSharesPage"
             Title="My Portfolio"
             BackgroundColor="#121212"
             xmlns:models="clr-namespace:ProjectCompScience.Models"
             xmlns:viewmodels="clr-namespace:ProjectCompScience.ViewModels">

    <ContentPage.BindingContext>
        <viewmodels:ViewModelShare />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20" RowSpacing="15">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
            <Label Grid.Column="0" Text="Your Assets" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
            <Label Grid.Column="1" Text="{Binding StockShares.Count, StringFormat='{0} Positions'}" TextColor="#888" VerticalOptions="Center"/>
        </Grid>

        <Border Grid.Row="1" Stroke="#333" BackgroundColor="#252525" Padding="15" StrokeShape="RoundRectangle 8">

            <Grid ColumnDefinitions="Auto, *, Auto" HorizontalOptions="Fill" VerticalOptions="Center">

                <GraphicsView x:Name="PortfolioPieChartView"
                              Grid.Column="0"
                              HeightRequest="140" 
                              WidthRequest="140" 
                              VerticalOptions="Center" />

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="25,0,0,0" BindableLayout.ItemsSource="{Binding MyPieChart.Slices}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <HorizontalStackLayout Spacing="10" Margin="0,4">
                                <BoxView Color="{Binding SliceColor}" WidthRequest="14" HeightRequest="14" CornerRadius="3" VerticalOptions="Center"/>
                                <Label Text="{Binding Ticker}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" FontSize="13"/>
                                <Label Text="{Binding Percentage, StringFormat='{0:F1}%'}" TextColor="#AAAAAA" VerticalOptions="Center" FontSize="13"/>
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="5" Margin="10,0,0,0">
                    <Label Text="TOTAL VALUE" TextColor="#888" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="End"/>

                    <Label Text="{Binding TotalPortfolioValue, StringFormat='${0:N2}'}" TextColor="#4CAF50" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="End"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <CollectionView Grid.Row="2" ItemsSource="{Binding StockShares}">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50,0,0" Spacing="10">
                    <Label Text="📈" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="No Shares To Show!" TextColor="#888" FontSize="16" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PortfolioItem">
                    <Frame BackgroundColor="#1E1E1E" 
                           BorderColor="#333" 
                           CornerRadius="4" 
                           Padding="10" 
                           Margin="0,0,0,8" 
                           HasShadow="False">

                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">

                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                                <Label Text="{Binding Ticker}" FontAttributes="Bold" FontSize="18" TextColor="White" />
                                <Label Text="{Binding CompanyName}" FontSize="11" TextColor="#888" />
                            </StackLayout>

                            <StackLayout Grid.Row="0" Grid.Column="1" Orientation="Vertical" HorizontalOptions="End">
                                <Label Text="{Binding TotalShares, StringFormat='{0} Shrs'}" FontSize="14" FontAttributes="Bold" TextColor="White" />
                                <Label Text="{Binding AveragePurchasePrice, StringFormat='Avg: ${0:F2}'}" FontSize="11" TextColor="#888" />
                            </StackLayout>

                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                                <Button Grid.Column="0" 
                                        Text="DETAILS" 
                                        HeightRequest="32" 
                                        FontSize="11"
                                        BackgroundColor="#444"
                                        TextColor="White"
                                        CornerRadius="2"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ViewModelShare}}, Path=GoToDetailsCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Grid.Column="1" 
                                        Text="SELL" 
                                        HeightRequest="32" 
                                        FontSize="11"
                                        BackgroundColor="#CC3333"
                                        TextColor="White"
                                        CornerRadius="2"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ViewModelShare}}, Path=ButtonDeleteShareCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="3"
                Text="+ Find New Stocks"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="8"
                HeightRequest="50"
                Command="{Binding ButtonMovePageCommand}" />

    </Grid>
</ContentPage>