<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectCompScience.View.StockSharesPage"
             Title="My Portfolio"
             BackgroundColor="#121212"
             xmlns:models="clr-namespace:ProjectCompScience.Models"
             xmlns:viewmodels="clr-namespace:ProjectCompScience.ViewModels">

    <ContentPage.BindingContext>
        <viewmodels:ViewModelShare />
    </ContentPage.BindingContext>

 
    <StackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
            <Label Grid.Column="0" Text="Your Assets" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
            <Label Grid.Column="1" Text="{Binding StockShares.Count, StringFormat='{0} Positions'}" TextColor="#888" VerticalOptions="Center"/>
        </Grid>


        <CollectionView ItemsSource="{Binding StockShares}">

         
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50,0,0" Spacing="10">
                    <Label Text="📈" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="No Shares To Show!" TextColor="#888" FontSize="16" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PortfolioItem">
                    <Frame BackgroundColor="#1E1E1E" 
                          BorderColor="#333" 
                          CornerRadius="4" 
                          Padding="10" 
                          Margin="0,0,0,8" 
                          HasShadow="False">

                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">

                            
                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                                <Label Text="{Binding Ticker}" FontAttributes="Bold" FontSize="18" TextColor="White" />
                                <Label Text="{Binding CompanyName}" FontSize="11" TextColor="#888" />
                            </StackLayout>

                            <StackLayout Grid.Row="0" Grid.Column="1" Orientation="Vertical" HorizontalOptions="End">
                                <Label Text="{Binding TotalShares, StringFormat='{0} Shrs'}" FontSize="14" FontAttributes="Bold" TextColor="White" />
                                <Label Text="{Binding AveragePurchasePrice, StringFormat='Avg: ${0:F2}'}" FontSize="11" TextColor="#888" />
                            </StackLayout>

                          
                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">

                                <Button Grid.Column="0" 
                                        Text="DETAILS" 
                                        HeightRequest="32" 
                                        FontSize="11"
                                        BackgroundColor="#444"
                                        TextColor="White"
                                        CornerRadius="2"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ViewModelShare}}, Path=GoToDetailsCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Grid.Column="1" 
                                        Text="SELL" 
                                        HeightRequest="32" 
                                        FontSize="11"
                                        BackgroundColor="#CC3333"
                                        TextColor="White"
                                        CornerRadius="2"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ViewModelShare}}, Path=ButtonDeleteShareCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+ Find New Stocks"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="8"
                HeightRequest="50"
                Margin="0,10,0,0"
                Command="{Binding ButtonMovePageCommand}" />

    </StackLayout>
</ContentPage>