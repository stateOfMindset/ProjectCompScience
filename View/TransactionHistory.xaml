<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ProjectCompScience.ViewModels"
             x:Class="ProjectCompScience.View.TransactionHistory"
             Title="Transaction History"
             BackgroundColor="#121212">

    <Grid>
        <!-- The List of Transactions -->
        <CollectionView ItemsSource="{Binding Transactions}" Margin="15">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,5,0,5" BorderColor="Transparent">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TransactionHistoryViewModel}}, Path=TransactionTappedCommand}" 
                                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <!-- Left Side: Ticker, Action, & Company Name -->
                            <Label Text="{Binding Ticker}" FontSize="18" FontAttributes="Bold" TextColor="White" Grid.Column="0" Grid.Row="0"/>

                            <HorizontalStackLayout Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,2,0,0">
                                <!-- Shows "Buy" or "Sell" -->
                                <Label Text="{Binding Type}" FontSize="14" FontAttributes="Bold" TextColor="#AAAAAA"/>
                                <!-- A little dot to separate them -->
                                <Label Text="•" FontSize="14" TextColor="#555555"/>
                                <!-- Shows company name -->
                                <Label Text="{Binding CompanyName}" FontSize="14" TextColor="#888888" LineBreakMode="TailTruncation"/>
                            </HorizontalStackLayout>

                            <!-- Right Side: Total Price & Date -->
                            <Label Text="{Binding TotalPrice, StringFormat='${0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="#2ECC71" Grid.Column="1" Grid.Row="0" HorizontalOptions="End"/>
                            <Label Text="{Binding Date, StringFormat='{0:MMM dd, yyyy}'}" FontSize="12" TextColor="#AAAAAA" Grid.Column="1" Grid.Row="1" HorizontalOptions="End"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" Color="#2ECC71"/>
    </Grid>
</ContentPage>