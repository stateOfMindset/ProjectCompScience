<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProjectCompScience.ShellAuth"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProjectCompScience"
    xmlns:View="clr-namespace:ProjectCompScience.View"
    Shell.FlyoutBehavior="Flyout"
    Title="ProjectCompScience"
    FlowDirection="LeftToRight"
    >

    <TabBar>

        <Tab Title="addNew shares">
            <ShellContent
            Title="buyShares"
            ContentTemplate="{DataTemplate View:BuyShares}"
            Route="BuyShares" />
        </Tab>

        

        <Tab Title="StockSharesPage">
            <ShellContent
            Title="StockSharesPage"
            ContentTemplate="{DataTemplate View:StockSharesPage}"
            Route="StockSharesPage" />
        </Tab>

        <Tab Title="TransactionHistory">
            <ShellContent
             Title="TransactionHistory"
             ContentTemplate="{DataTemplate View:TransactionHistory}"
             Route="TransactionHistory" />
        </Tab>



    </TabBar>

</Shell>
